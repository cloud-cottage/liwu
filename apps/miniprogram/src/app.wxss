page {
  min-height: 100%;
  background: linear-gradient(180deg, #f3f0ea 0%, #f8f5ef 100%);
  color: #1f2937;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  padding: 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 126rpx);
  position: relative;
  box-sizing: border-box;
}

.page-shell::before {
  content: '';
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 16% 14%, rgba(143, 165, 138, 0.14) 0, transparent 22%),
    radial-gradient(circle at 82% 16%, rgba(214, 206, 190, 0.18) 0, transparent 20%),
    repeating-linear-gradient(135deg, transparent 0 44rpx, rgba(143, 165, 138, 0.05) 44rpx 88rpx);
  opacity: 0.84;
}

.section-card {
  position: relative;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid rgba(143, 165, 138, 0.12);
  backdrop-filter: blur(12rpx);
}

.page-header {
  position: relative;
  z-index: 1;
  margin: 8rpx 0 24rpx;
}

.page-masthead {
  position: relative;
  z-index: 1;
  margin: 8rpx 0 24rpx;
}

.page-masthead__pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 165, 138, 0.12);
  color: #8b5e34;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.page-masthead__title {
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #1f2937;
}

.page-masthead__slogan {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.page-title {
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #1f2937;
}

.page-caption {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.section-kicker {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #8fa58a;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.section-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.primary-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 16rpx 30rpx rgba(143, 165, 138, 0.24);
}

.ghost-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 84rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #4d5a4b;
  font-size: 26rpx;
  font-weight: 600;
  border: 1rpx solid rgba(143, 165, 138, 0.18);
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 165, 138, 0.12);
  color: #4d5a4b;
  font-size: 22rpx;
  font-weight: 600;
}
