.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  padding: 0 0 env(safe-area-inset-bottom);
  pointer-events: none;
}

.tabbar-panel {
  min-height: 104rpx;
  background: rgba(243, 240, 234, 0.98);
  border-top: 1rpx solid rgba(143, 165, 138, 0.16);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.05);
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: 6rpx 8rpx 4rpx;
  pointer-events: auto;
}

.tabbar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #6b7280;
  position: relative;
  min-height: 94rpx;
}

.tabbar-item-active {
  color: #8b5e34;
}

.tabbar-indicator {
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: transparent;
  margin-bottom: 2rpx;
}

.tabbar-item-active .tabbar-indicator {
  background: #8b5e34;
}

.tabbar-icon-image {
  width: 46rpx;
  height: 46rpx;
  display: block;
  opacity: 0.92;
}

.tabbar-label {
  font-size: 18rpx;
  line-height: 1.2;
  font-weight: 600;
  letter-spacing: 0;
}
