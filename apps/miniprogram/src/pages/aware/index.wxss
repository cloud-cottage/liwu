.aware-page-shell {
  padding-bottom: 44rpx;
}

.composer-card,
.common-card,
.cloud-card {
  margin-bottom: 24rpx;
}

.composer-card {
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.aware-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(248, 245, 239, 0.92);
  font-size: 28rpx;
  color: #1f2937;
}

.publish-button {
  width: 100%;
  margin-top: 18rpx;
}

.tag-pills {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-pill,
.cloud-tag {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(143, 165, 138, 0.18);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
  color: #1f2937;
  line-height: 1.2;
  font-weight: 600;
}

.cloud-wrap {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx 16rpx;
  justify-content: center;
  min-height: 156rpx;
  align-content: center;
}

.cloud-tag-student {
  border-style: dashed;
  background: rgba(255, 255, 255, 0.86);
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-card {
  position: relative;
  width: 100%;
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  box-sizing: border-box;
}

.modal-close-chip {
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #475569;
  font-size: 22rpx;
}

.modal-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.modal-chip {
  flex-shrink: 0;
}

.modal-intro {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(143, 165, 138, 0.1);
  color: #475569;
  font-size: 25rpx;
  line-height: 1.7;
}

.modal-meta-group {
  margin-top: 18rpx;
  display: grid;
  gap: 10rpx;
}

.modal-meta {
  font-size: 24rpx;
  line-height: 1.6;
  color: #475569;
}

.related-product-card {
  margin-top: 18rpx;
  border: 1rpx solid rgba(143, 165, 138, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  padding: 14rpx;
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 14rpx;
  align-items: center;
}

.related-product-image,
.related-product-fallback {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
}

.related-product-fallback {
  background: rgba(248, 245, 239, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 22rpx;
}

.related-product-body {
  min-width: 0;
}

.related-product-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #8fa58a;
}

.related-product-title {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.related-product-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}

.modal-button {
  width: 100%;
  margin-top: 18rpx;
}

.empty-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #6b7280;
}
