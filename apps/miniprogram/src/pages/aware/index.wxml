<view class="page-shell aware-page-shell">
  <view class="page-masthead">
    <view class="page-masthead__pill">Awareness</view>
    <view class="page-masthead__title">觉察</view>
    <view class="page-masthead__slogan">{{awarenessSlogan}}</view>
  </view>

  <view class="section-card composer-card">
    <view class="composer-body">
      <input
        class="aware-input"
        placeholder="属于你的此刻觉察"
        maxlength="6"
        value="{{inputValue}}"
        bindinput="handleInput"
      />
      <view class="aware-input-meta">{{inputValue.length}}/6</view>
      <button class="primary-button publish-button" loading="{{saving}}" disabled="{{saving || loading}}" bindtap="handlePublish">
        觉察此刻
      </button>
    </view>
  </view>

  <view class="section-card common-card" wx:if="{{myTags.length}}">
    <view class="section-title">我的常用觉察</view>
    <view class="tag-pills">
      <view class="tag-pill" wx:for="{{myTags}}" wx:key="key">{{item.content}}</view>
    </view>
  </view>

  <view class="section-card cloud-card">
    <view class="section-title">同心照亮</view>
    <view class="cloud-wrap" wx:if="{{popularTags.length}}" style="height: {{cloudHeight}}rpx;">
      <view
        class="cloud-tag {{item.accessType === 'student' ? 'cloud-tag-student' : ''}}"
        wx:for="{{popularTags}}"
        wx:key="key"
        data-tag="{{item}}"
        bindtap="handleTagTap"
        style="{{item.style}}"
      >
        {{item.content}}
      </view>
    </view>
    <view class="empty-text" wx:else>还没有可展示的社区觉察标签。</view>
  </view>

  <view class="modal-mask" wx:if="{{showTagModal}}" bindtap="handleCloseTagModal">
    <view class="modal-card" catchtap="noop">
      <view class="modal-close-chip" bindtap="handleCloseTagModal">关闭</view>
      <view class="modal-title-row">
        <view class="modal-title">{{activeTag.content}}</view>
        <view class="status-chip modal-chip" wx:if="{{activeTag.accessType === 'student'}}">学员觉察</view>
      </view>

      <view class="modal-intro" wx:if="{{activeTag.description}}">{{activeTag.description}}</view>

      <view class="modal-meta-group">
        <view class="modal-meta">已与 {{activeTag.participantCount || 0}} 人一起共同创造，社区总累计 {{activeTag.totalCount || 0}} 次</view>
        <view class="modal-meta">本周最多 {{activeTag.weeklyChampionName || '匿名用户'}} - 最新觉察 {{activeTag.lastUserName || '匿名用户'}}</view>
      </view>

      <view class="related-product-card" wx:if="{{activeTag.relatedProduct}}" data-product-id="{{activeTag.relatedProduct.id}}" bindtap="handleOpenRelatedProduct">
        <image wx:if="{{activeTag.relatedProduct.coverImage}}" class="related-product-image" mode="aspectFill" src="{{activeTag.relatedProduct.coverImage}}" />
        <view wx:else class="related-product-fallback">商品</view>
        <view class="related-product-body">
          <view class="related-product-label">相关商品</view>
          <view class="related-product-title">{{activeTag.relatedProduct.name}}</view>
          <view class="related-product-subtitle">{{activeTag.relatedProduct.subtitle}}</view>
        </view>
      </view>

      <button class="primary-button modal-button" loading="{{saving}}" disabled="{{saving}}" bindtap="handleRepublishTag">
        我也觉察它
      </button>
      <button class="ghost-button modal-button" open-type="share" data-share-type="tag">
        分享觉察
      </button>
      <button class="ghost-button modal-button" bindtap="handleCloseTagModal">关闭</button>
    </view>
  </view>
</view>
