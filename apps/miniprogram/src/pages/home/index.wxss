.hero-card {
  background: linear-gradient(180deg, #fff8f1 0%, #ffffff 100%);
  margin-bottom: 24rpx;
}

.hero-label {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: #c2410c;
}

.hero-button {
  margin-top: 24rpx;
}

.quick-card,
.tag-card {
  margin-bottom: 24rpx;
}

.quick-list {
  margin-top: 20rpx;
  display: grid;
  gap: 16rpx;
}

.quick-item {
  border-radius: 24rpx;
  background: #f8fafc;
  padding: 20rpx;
}

.quick-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.quick-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.tag-list {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.1);
  color: #2563eb;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-text {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #94a3b8;
}
