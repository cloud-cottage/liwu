.home-page-shell {
  padding-bottom: 44rpx;
}

.app-tagline-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 165, 138, 0.12);
  color: #8b5e34;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.hero-swiper-shell {
  margin-bottom: 24rpx;
}

.hero-swiper {
  width: 100%;
  height: 380rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.12);
}

.hero-slide {
  position: relative;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
}

.hero-slide-gradient {
  background:
    linear-gradient(180deg, rgba(15, 23, 42, 0.08) 0%, rgba(15, 23, 42, 0.28) 100%),
    linear-gradient(135deg, #d9e2d3 0%, #a7b69a 100%);
}

.hero-bubble {
  position: absolute;
  left: 20rpx;
  bottom: 20rpx;
  max-width: 76%;
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(71, 85, 105, 0.52);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1.65;
}

.practice-card {
  margin-bottom: 24rpx;
  min-height: 306rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  text-align: center;
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.18), transparent 36%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.practice-orb {
  margin-top: 18rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  box-shadow: 0 20rpx 40rpx rgba(143, 165, 138, 0.24);
}

.practice-title {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.practice-subtitle {
  margin-top: 10rpx;
  max-width: 86%;
  font-size: 23rpx;
  line-height: 1.7;
  color: #6b7280;
}

.showcase-card {
  margin-bottom: 24rpx;
}

.showcase-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.showcase-grid {
  margin-top: 18rpx;
  aspect-ratio: 1 / 1;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  grid-template-rows: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
}

.showcase-tile {
  position: relative;
  border-radius: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(143, 165, 138, 0.18), rgba(167, 182, 154, 0.36));
}

.showcase-tile-1 {
  grid-column: 1 / span 2;
  grid-row: 1 / span 2;
}

.showcase-tile-2 {
  grid-column: 3 / span 2;
  grid-row: 1 / span 1;
}

.showcase-tile-3 {
  grid-column: 3 / span 1;
  grid-row: 2 / span 2;
}

.showcase-tile-4 {
  grid-column: 1 / span 4;
  grid-row: 3 / span 2;
}

.showcase-image,
.showcase-fallback {
  width: 100%;
  height: 100%;
}

.showcase-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4d5a4b;
  font-size: 68rpx;
  font-weight: 700;
}

.showcase-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 18%, rgba(0, 0, 0, 0.3) 100%);
}

.showcase-name {
  position: absolute;
  left: 14rpx;
  right: 14rpx;
  bottom: 14rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1.4;
  font-weight: 600;
}

.showcase-empty {
  margin-top: 18rpx;
  min-height: 280rpx;
  border-radius: 20rpx;
  background: rgba(248, 245, 239, 0.88);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #6b7280;
  font-size: 24rpx;
}

.empty-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #6b7280;
}
