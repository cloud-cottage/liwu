.meditation-page-shell {
  padding-bottom: 44rpx;
}

.meditation-hero-card {
  min-height: 660rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.18), transparent 32%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 245, 239, 0.94) 100%);
}

.meditation-kicker {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #111827;
}

.meditation-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.meditation-console {
  margin-top: 28rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.meditation-disc {
  width: 248rpx;
  height: 248rpx;
  border-radius: 999rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.meditation-disc-ring {
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
  border: 2rpx solid rgba(143, 165, 138, 0.16);
  box-shadow:
    inset 0 0 0 16rpx rgba(255, 255, 255, 0.58),
    0 24rpx 48rpx rgba(143, 165, 138, 0.14);
}

.meditation-orb {
  width: 148rpx;
  height: 148rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 700;
  box-shadow: 0 22rpx 44rpx rgba(143, 165, 138, 0.24);
}

.meditation-timer {
  margin-top: 28rpx;
  font-size: 92rpx;
  line-height: 1;
  font-weight: 700;
  color: #1f2937;
}

.meditation-button {
  width: 100%;
  margin-top: 32rpx;
}

.meditation-actions {
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 14rpx;
}

.meditation-action-button {
  width: 100%;
}

.meditation-stats-card {
  margin-top: 24rpx;
  text-align: center;
}

.meditation-stats-line {
  font-size: 24rpx;
  color: #6b7280;
  opacity: 0.78;
}
