<view class="page-shell meditation-page-shell">
  <view class="page-header">
    <view class="page-title">静寂</view>
    <view class="page-caption">给自己 15 分钟的留白。</view>
  </view>

  <view class="section-card meditation-hero-card">
    <view class="meditation-kicker">当下即是献礼</view>
    <view class="meditation-subtitle">在呼吸间寻回内在的秩序。</view>

    <view class="meditation-console">
      <view class="meditation-disc">
        <view class="meditation-disc-ring"></view>
        <view class="meditation-orb">静</view>
      </view>
      <view class="meditation-timer">{{timeLabel}}</view>
    </view>

    <button class="primary-button meditation-button" loading="{{saving}}" disabled="{{saving}}" bindtap="handleToggleMeditation">
      {{running ? '暂停静寂' : '冥想此刻'}}
    </button>

    <view class="meditation-actions">
      <button class="ghost-button meditation-action-button" bindtap="handleResetMeditation">重新开始</button>
      <button class="ghost-button meditation-action-button" open-type="share">分享静寂</button>
    </view>
  </view>

  <view class="meditation-stats-card">
    <view class="meditation-stats-line">往日 {{stats.pastCount}} → 今日 {{stats.todayCount}} → 来日 ∞</view>
  </view>
</view>
