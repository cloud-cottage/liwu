.profile-card,
.editor-card,
.shop-entry {
  margin-bottom: 24rpx;
}

.stats-row {
  margin-top: 20rpx;
  display: grid;
  gap: 16rpx;
}

.stat-box {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.stat-label {
  font-size: 22rpx;
  color: #64748b;
}

.stat-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #0f172a;
  word-break: break-all;
}

.field-label {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #334155;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  background: #f8fafc;
  font-size: 26rpx;
}

.field-textarea {
  min-height: 150rpx;
}

.save-button,
.shop-button {
  width: 100%;
  margin-top: 22rpx;
}
