.profile-page-shell {
  padding-bottom: 44rpx;
}

.profile-status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.status-card {
  min-height: 152rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.status-card-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #7c6855;
  letter-spacing: 0.04em;
}

.status-card-value {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #111827;
}

.status-card-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.profile-card,
.editor-card {
  margin-bottom: 24rpx;
}

.profile-card {
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.14), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.profile-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-meta {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.profile-bio {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6b7280;
}

.profile-expire {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8b5e34;
}

.profile-stats {
  margin-top: 22rpx;
  display: grid;
  gap: 14rpx;
}

.profile-stat {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(248, 245, 239, 0.92);
}

.profile-stat-label {
  font-size: 22rpx;
  color: #6b7280;
}

.profile-stat-value {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #1f2937;
  word-break: break-all;
}

.profile-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.action-card {
  min-height: 168rpx;
  display: flex;
  justify-content: center;
  flex-direction: column;
  background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,245,239,0.92) 100%);
}

.action-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.action-subtitle {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #6b7280;
}

.field-label {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #374151;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(248, 245, 239, 0.92);
  font-size: 26rpx;
  color: #1f2937;
}

.field-textarea {
  min-height: 150rpx;
}

.save-button {
  width: 100%;
  margin-top: 22rpx;
}

.wealth-list {
  margin-top: 18rpx;
  display: grid;
  gap: 12rpx;
}

.wealth-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: rgba(248, 245, 239, 0.92);
  border: 1rpx solid rgba(143, 165, 138, 0.08);
}

.wealth-item-body {
  min-width: 0;
  flex: 1;
}

.wealth-item-title {
  font-size: 24rpx;
  color: #1f2937;
}

.wealth-item-time {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #6b7280;
}

.wealth-item-amount {
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 700;
}

.wealth-item-amount-earn {
  color: #166534;
}

.wealth-item-amount-spend {
  color: #4d5a4b;
}

.tag-pills {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(143, 165, 138, 0.18);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 600;
}

.empty-text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #6b7280;
}
