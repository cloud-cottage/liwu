.album-page-shell {
  padding-bottom: 44rpx;
}

.album-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.album-tab {
  min-height: 164rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.album-tab-active {
  border: 1rpx solid rgba(143, 165, 138, 0.24);
  box-shadow: 0 18rpx 40rpx rgba(143, 165, 138, 0.12);
}

.album-tab-kicker {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: #8fa58a;
}

.album-tab-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.album-tab-count {
  font-size: 26rpx;
  font-weight: 700;
  color: #8b5e34;
}

.badge-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.badge-card {
  display: grid;
  justify-items: center;
  gap: 12rpx;
  text-align: center;
  min-height: 332rpx;
  padding-top: 24rpx;
}

.badge-card-earned {
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.96) 100%);
}

.badge-card-locked {
  background: linear-gradient(180deg, rgba(255,255,255,0.92) 0%, rgba(243,244,246,0.96) 100%);
}

.badge-card-equipped {
  border: 1rpx solid rgba(143, 165, 138, 0.26);
}

.badge-art {
  width: 132rpx;
  height: 132rpx;
  border-radius: 999rpx;
  position: relative;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(143, 165, 138, 0.18);
}

.badge-art-locked {
  filter: grayscale(1);
  opacity: 0.58;
}

.badge-core {
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.badge-difficulty {
  position: absolute;
  right: 0;
  top: 6rpx;
  min-width: 52rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.82);
  color: #ffffff;
  font-size: 18rpx;
  line-height: 1.2;
}

.badge-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
}

.badge-copy {
  display: grid;
  gap: 8rpx;
}

.badge-summary {
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}

.badge-equipped {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(143, 165, 138, 0.14);
  color: #4d5a4b;
  font-size: 20rpx;
  font-weight: 700;
}

.album-empty-card {
  text-align: center;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-modal-card {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.modal-intro {
  margin-top: 18rpx;
  font-size: 25rpx;
  line-height: 1.7;
  color: #475569;
}

.badge-modal-metrics {
  margin-top: 18rpx;
  display: grid;
  gap: 12rpx;
}

.badge-modal-metric {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(248, 245, 239, 0.92);
}

.badge-modal-metric-label {
  font-size: 22rpx;
  color: #6b7280;
}

.badge-modal-metric-value {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #1f2937;
  font-weight: 600;
}

.badge-modal-hint {
  margin-top: 18rpx;
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
}

.modal-button {
  width: 100%;
  margin-top: 18rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #6b7280;
}
