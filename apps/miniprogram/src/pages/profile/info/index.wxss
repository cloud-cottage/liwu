.profile-info-shell {
  padding-bottom: 44rpx;
}

.profile-info-card,
.profile-info-editor {
  margin-bottom: 24rpx;
}

.profile-info-card {
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.14), transparent 34%),
    linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.profile-info-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.profile-info-avatar {
  width: 116rpx;
  height: 116rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #8fa58a, #a7b69a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.profile-info-meta {
  flex: 1;
  min-width: 0;
}

.profile-info-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.profile-info-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.profile-info-chip-row {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.profile-info-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.16);
  color: #94a3b8;
  font-size: 20rpx;
  font-weight: 600;
}

.profile-info-chip-active {
  background: rgba(15, 118, 110, 0.12);
  color: #0f766e;
}

.profile-info-expire {
  font-size: 22rpx;
  color: #8b5e34;
}

.field-label {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #374151;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: rgba(248, 245, 239, 0.92);
  font-size: 26rpx;
  color: #1f2937;
}

.field-textarea {
  min-height: 160rpx;
}

.profile-info-save {
  width: 100%;
  margin-top: 24rpx;
}
