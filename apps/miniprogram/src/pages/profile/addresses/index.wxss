.address-list {
  display: grid;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.address-card {
  display: grid;
  gap: 8rpx;
}

.address-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.address-detail {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.7;
}

.address-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  font-size: 24rpx;
}

.save-button {
  width: 100%;
  margin-top: 20rpx;
}
