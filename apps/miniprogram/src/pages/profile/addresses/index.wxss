.addresses-page-shell {
  padding-bottom: 44rpx;
}

.address-list {
  display: grid;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.address-card,
.editor-card {
  display: grid;
  gap: 10rpx;
}

.address-card {
  background: linear-gradient(180deg, rgba(255,255,255,0.98) 0%, rgba(248,245,239,0.94) 100%);
}

.address-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.address-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
}

.address-detail {
  font-size: 22rpx;
  line-height: 1.7;
  color: #6b7280;
}

.address-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: rgba(248, 245, 239, 0.92);
  font-size: 24rpx;
  color: #1f2937;
}

.save-button {
  width: 100%;
  margin-top: 20rpx;
}
