.shop-page-shell {
  padding-bottom: 48rpx;
}

.shop-page-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(143, 165, 138, 0.12);
  color: #8b5e34;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  margin-bottom: 12rpx;
}

.shop-wallet-card {
  background:
    radial-gradient(circle at top right, rgba(143, 165, 138, 0.14), transparent 34%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(243, 240, 234, 0.9) 100%);
  margin-bottom: 24rpx;
}

.shop-wallet-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
}

.modal-label,
.shop-section-kicker {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.18em;
  color: #8fa58a;
  text-transform: uppercase;
}

.shop-wallet-label {
  font-size: 22rpx;
  color: #4d5a4b;
  font-weight: 600;
}

.shop-wallet-value {
  margin-top: 12rpx;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 700;
  color: #111827;
}

.shop-cart-button {
  width: 112rpx;
  height: 112rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(148, 163, 184, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.living-card {
  margin-bottom: 24rpx;
}

.living-head {
  display: block;
}

.living-subtitle {
  margin-top: 12rpx;
}

.living-swiper {
  width: 100%;
  height: 640rpx;
  margin-top: 18rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 18rpx 48rpx rgba(15, 23, 42, 0.1);
}

.living-slide {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
  overflow: hidden;
}

.living-image {
  width: 100%;
  height: 100%;
  display: block;
}

.living-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0.04) 0%, rgba(15, 23, 42, 0.18) 100%);
}

.living-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.living-hotspot {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 128rpx;
  height: 128rpx;
  transform: translate(-50%, -50%);
  border-radius: 999rpx;
}

.shop-cart-icon {
  width: 40rpx;
  height: 40rpx;
  display: block;
}

.shop-section-head {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-start;
}

.shop-section-kicker {
  color: #94a3b8;
}

.shop-section-kicker-light {
  margin-bottom: 8rpx;
}

.shop-list-head-main {
  display: block;
}

.shop-list-tabs {
  width: 100%;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.category-pill {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 24rpx;
  font-weight: 600;
  white-space: nowrap;
}

.category-pill-active {
  background: #4d5a4b;
  color: #ffffff;
}

.shop-section-head-list {
  margin-bottom: 18rpx;
}

.product-list {
  display: grid;
  gap: 22rpx;
}

.product-card {
  padding: 0;
  overflow: hidden;
}

.product-visual,
.modal-hero {
  position: relative;
  min-height: 240rpx;
  padding: 22rpx;
  overflow: hidden;
}

.product-badge-row {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.product-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #1f2937;
  font-size: 22rpx;
  font-weight: 600;
}

.product-badge-soft {
  background: rgba(255, 255, 255, 0.62);
  color: #475569;
}

.product-monogram {
  position: absolute;
  right: 24rpx;
  bottom: 14rpx;
  z-index: 2;
  font-size: 120rpx;
  line-height: 1;
  font-weight: 700;
  opacity: 0.72;
}

.product-shadow {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: -44rpx;
  height: 96rpx;
  border-radius: 32rpx;
  opacity: 0.56;
}

.product-body {
  padding: 24rpx 28rpx 28rpx;
}

.product-header {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: flex-start;
}

.product-title-block {
  flex: 1;
  min-width: 0;
}

.product-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.product-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.product-link {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #475569;
  font-size: 22rpx;
  font-weight: 600;
}

.product-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.product-meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #64748b;
  font-size: 22rpx;
}

.product-footer {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  align-items: baseline;
  margin-top: 22rpx;
}

.product-price {
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.product-action {
  font-size: 22rpx;
  font-weight: 600;
  color: #4d5a4b;
}

.empty-card {
  margin-top: 12rpx;
}

.empty-text {
  font-size: 24rpx;
  color: #94a3b8;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  padding: 32rpx;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-card {
  position: relative;
  width: 100%;
  max-height: calc(100vh - 64rpx);
  overflow: auto;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 0 28rpx 28rpx;
  box-sizing: border-box;
}

.modal-hero-actions {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  z-index: 3;
  display: flex;
  gap: 10rpx;
}

.modal-icon-button {
  min-width: 84rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #475569;
  font-size: 22rpx;
  line-height: 1.2;
  text-align: center;
}

.modal-label {
  margin-top: 24rpx;
  color: #94a3b8;
}

.modal-title-row {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
}

.modal-title-block {
  flex: 1;
  min-width: 0;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.modal-intro {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #475569;
}

.modal-price-tag {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #f8fafc;
  color: #4d5a4b;
  font-size: 22rpx;
  font-weight: 700;
}

.modal-metrics {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.modal-metric {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.related-product-card {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid rgba(143, 165, 138, 0.16);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.96);
  padding: 14rpx;
  display: grid;
  grid-template-columns: 96rpx 1fr;
  gap: 14rpx;
  align-items: center;
}

.related-product-image,
.related-product-fallback {
  width: 96rpx;
  height: 96rpx;
  border-radius: 14rpx;
}

.related-product-fallback {
  background: rgba(248, 245, 239, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6b7280;
  font-size: 22rpx;
}

.related-product-body {
  min-width: 0;
}

.related-product-label {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #8fa58a;
}

.related-product-title {
  margin-top: 6rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #111827;
}

.related-product-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #6b7280;
}

.modal-metric-label {
  font-size: 22rpx;
  color: #64748b;
}

.modal-metric-value {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.modal-section {
  margin-top: 24rpx;
}

.modal-section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.modal-section-kicker {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8fa58a;
}

.sku-list {
  margin-top: 16rpx;
  display: grid;
  gap: 12rpx;
}

.sku-card {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
}

.sku-card-active {
  border-color: #111827;
  background: #f1f5f9;
}

.sku-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0f172a;
}

.sku-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
}

.address-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 10rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e2e8f0;
  background: #ffffff;
  font-size: 24rpx;
}

.modal-button {
  width: 100%;
  margin-top: 22rpx;
}

.modal-secondary-button {
  margin-top: 18rpx;
}
