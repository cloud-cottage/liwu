<view class="page-shell shop-page-shell">
  <view class="page-masthead">
    <view class="page-masthead__pill">Liwu for Myself</view>
    <view class="page-masthead__title">工坊</view>
    <view class="page-masthead__slogan">{{shopSlogan}}</view>
  </view>

  <view class="section-card shop-wallet-card">
    <view class="shop-wallet-head">
      <view>
        <view class="shop-wallet-label">当前福豆</view>
        <view class="shop-wallet-value">{{walletBalance}}</view>
      </view>
      <view class="shop-cart-button" bindtap="handleCartTap">
        <image class="shop-cart-icon" mode="aspectFit" src="/assets/shop/cart.svg" />
      </view>
    </view>
  </view>

  <view class="section-card living-card">
    <view class="living-head">
      <view>
        <view class="shop-section-kicker">My Space</view>
        <view class="section-title">我的居心地</view>
      </view>
    </view>
    <view class="section-subtitle living-subtitle">每个人都有属于自己的空间。</view>

    <swiper
      class="living-swiper"
      circular
      autoplay
      interval="4200"
      duration="480"
      indicator-dots
      indicator-color="rgba(255,255,255,0.42)"
      indicator-active-color="#ffffff"
      current="{{currentLivingIndex}}"
      bindchange="handleLivingSwiperChange"
    >
      <swiper-item wx:for="{{livingCards}}" wx:key="id">
        <view class="living-slide">
          <image class="living-image" mode="aspectFill" src="{{item.imageUrl}}" />
          <view class="living-overlay"></view>
          <canvas type="2d" id="livingCanvas{{index}}" class="living-canvas"></canvas>
          <view
            wx:if="{{item.productId}}"
            class="living-hotspot"
            data-product-id="{{item.productId}}"
            bindtap="handleLivingCardTap"
          ></view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="shop-section-head shop-section-head-list" id="shop-list-section">
    <view class="shop-list-head-main">
      <view class="shop-section-kicker shop-section-kicker-light">Window</view>
      <view class="section-title shop-section-title">可兑换清单</view>
    </view>
    <view class="shop-list-tabs">
      <view
        class="category-pill {{activeCategoryId === item.id ? 'category-pill-active' : ''}}"
        wx:for="{{categoryTabs}}"
        wx:key="id"
        data-category-id="{{item.id}}"
        bindtap="handleCategoryTap"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="section-card empty-card">
    <view class="empty-text">正在加载工坊数据...</view>
  </view>

  <view wx:elif="{{products.length}}" class="product-list">
    <view
      class="section-card product-card"
      wx:for="{{products}}"
      wx:key="id"
      data-product-id="{{item.id}}"
      bindtap="handleProductTap"
    >
      <view class="product-visual" style="{{item.coverStyle}}">
        <view class="product-badge-row">
          <view class="product-badge">{{item.categoryName}}</view>
          <view class="product-badge product-badge-soft">{{item.badgeLabel}}</view>
        </view>
        <view wx:if="{{!item.coverImage}}" class="product-monogram" style="color: {{item.accentColor}};">{{item.monogram}}</view>
        <view class="product-shadow" style="box-shadow: 0 24rpx 40rpx {{item.shadowColor}};"></view>
      </view>

      <view class="product-body">
        <view class="product-header">
          <view class="product-title-block">
            <view class="product-title">{{item.name}}</view>
            <view class="product-subtitle">{{item.subtitleText}}</view>
          </view>
          <view class="product-link">查看</view>
        </view>

        <view class="product-meta">
          <view class="product-meta-pill">库存 {{item.stockTotal}}</view>
          <view class="product-meta-pill">已兑 {{item.salesCount}}</view>
          <view class="product-meta-pill">{{item.statusLabel}}</view>
        </view>

        <view class="product-footer">
          <view class="product-price">{{item.priceLabel}}</view>
          <view class="product-action">查看详情</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="section-card empty-card">
    <view class="empty-text">当前分类下还没有商品。</view>
  </view>

  <view class="modal-mask" wx:if="{{showProductModal}}" bindtap="handleCloseProductModal">
    <view class="modal-card" catchtap="noop">
      <view class="modal-hero" style="{{activeProduct.coverStyle}}">
        <view class="modal-hero-actions">
          <button class="modal-icon-button" open-type="share" data-share-type="product">分享</button>
          <view class="modal-icon-button" bindtap="handleCloseProductModal">关闭</view>
        </view>
        <view class="product-badge-row">
          <view class="product-badge">{{activeProduct.categoryName}}</view>
          <view class="product-badge product-badge-soft">{{activeProduct.statusLabel}}</view>
        </view>
        <view wx:if="{{activeProduct && !activeProduct.coverImage}}" class="product-monogram" style="color: {{activeProduct.accentColor}};">{{activeProduct.monogram}}</view>
      </view>

      <view class="modal-title-row">
        <view class="modal-title-block">
          <view class="modal-title">{{activeProduct.name}}</view>
          <view class="modal-intro">{{activeProduct.description || activeProduct.subtitle || '商品详情待补充'}}</view>
        </view>
        <view class="modal-price-tag" wx:if="{{selectedSkuSummary}}">{{selectedSkuSummary.priceLabel}}</view>
      </view>

      <view class="modal-metrics">
        <view class="modal-metric">
          <view class="modal-metric-label">销量</view>
          <view class="modal-metric-value">{{activeProduct.salesCount}}</view>
        </view>
        <view class="modal-metric">
          <view class="modal-metric-label">库存</view>
          <view class="modal-metric-value">{{activeProduct.stockTotal}}</view>
        </view>
        <view class="modal-metric">
          <view class="modal-metric-label">限购</view>
          <view class="modal-metric-value">{{activeProduct.limitPerUser || '不限'}}</view>
        </view>
        <view class="modal-metric">
          <view class="modal-metric-label">返豆</view>
          <view class="modal-metric-value">{{selectedSkuSummary.rewardPointsReturn || 0}}</view>
        </view>
      </view>

      <view class="modal-section" wx:if="{{activeProduct.relatedProduct}}">
        <view class="related-product-card" data-product-id="{{activeProduct.relatedProduct.id}}" bindtap="handleRelatedProductTap">
          <image wx:if="{{activeProduct.relatedProduct.coverImage}}" class="related-product-image" mode="aspectFill" src="{{activeProduct.relatedProduct.coverImage}}" />
          <view wx:else class="related-product-fallback">商品</view>
          <view class="related-product-body">
            <view class="related-product-label">相关商品</view>
            <view class="related-product-title">{{activeProduct.relatedProduct.name}}</view>
            <view class="related-product-subtitle">{{activeProduct.relatedProduct.subtitle}}</view>
          </view>
        </view>
      </view>

      <view class="modal-section" wx:if="{{activeProduct.skus.length}}">
        <view class="modal-section-kicker">规格选择</view>
        <view class="modal-section-title">挑一个适合此刻的版本</view>
        <view class="sku-list">
          <view
            class="sku-card {{selectedSkuId === item.id ? 'sku-card-active' : ''}}"
            wx:for="{{activeProduct.skus}}"
            wx:key="id"
            data-sku-id="{{item.id}}"
            bindtap="handleSkuTap"
          >
            <view class="sku-title">{{item.skuName || '默认规格'}}</view>
            <view class="sku-subtitle">{{item.priceLabel}} · 库存 {{item.stock}}</view>
          </view>
        </view>
      </view>

      <view class="modal-section">
        <view class="modal-section-kicker">交付方式</view>
        <view class="modal-section-title">{{activeProduct.productType === 'service' ? '线上交付，无需收货地址' : '实物寄送，需要收货地址'}}</view>
      </view>

      <view class="modal-section" wx:if="{{activeProduct.productType === 'physical'}}">
        <view class="modal-section-kicker">收货地址</view>
        <view class="modal-section-title">寄送到哪里</view>
        <input class="address-input" placeholder="收件人" data-field="receiverName" value="{{addressDraft.receiverName}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="手机号" data-field="phone" value="{{addressDraft.phone}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="省份" data-field="province" value="{{addressDraft.province}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="城市" data-field="city" value="{{addressDraft.city}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="区县" data-field="district" value="{{addressDraft.district}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="详细地址" data-field="detailAddress" value="{{addressDraft.detailAddress}}" bindinput="handleAddressInput" />
        <input class="address-input" placeholder="邮编" data-field="postalCode" value="{{addressDraft.postalCode}}" bindinput="handleAddressInput" />
        <button class="ghost-button modal-button modal-secondary-button" bindtap="handleSaveAddress">保存收货地址</button>
      </view>

      <button class="primary-button modal-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleCreateOrder">立即兑换</button>
    </view>
  </view>
</view>
