<view class="page-shell orders-page-shell">
  <view class="page-header">
    <view class="page-title">我的订单</view>
    <view class="page-caption">这里展示当前账号发起的工坊订单。</view>
  </view>

  <view wx:if="{{loading}}" class="section-card empty-card">
    <view class="empty-text">正在加载订单...</view>
  </view>

  <view wx:elif="{{orders.length}}" class="order-list">
    <view class="section-card order-card" wx:for="{{orders}}" wx:key="id">
      <view class="order-head">
        <view class="order-no">{{item.orderNo}}</view>
        <view class="status-chip">{{item.statusLabel}}</view>
      </view>

      <view class="order-summary">
        <view class="order-summary-item">
          <view class="order-summary-label">下单时间</view>
          <view class="order-summary-value">{{item.createdAtLabel}}</view>
        </view>
        <view class="order-summary-item">
          <view class="order-summary-label">商品数量</view>
          <view class="order-summary-value">{{item.itemCount}}</view>
        </view>
        <view class="order-summary-item">
          <view class="order-summary-label">合计</view>
          <view class="order-summary-value">{{item.totalPoints}} 福豆{{item.totalCash ? ' + ¥' + item.totalCash : ''}}</view>
        </view>
      </view>

      <view class="order-items">
        <view class="order-item" wx:for="{{item.items}}" wx:key="id">
          <view class="order-item-name">{{item.productName}}</view>
          <view class="order-item-subtitle">{{item.skuName || '默认规格'}} · x{{item.quantity}} · {{item.subtotalPoints}} 福豆</view>
        </view>
      </view>
    </view>
  </view>

  <view wx:else class="section-card empty-card">
    <view class="empty-text">还没有工坊订单。</view>
  </view>
</view>
