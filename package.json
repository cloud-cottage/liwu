{
  "name": "liwu",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:app",
    "dev:app": "npm --workspace @liwu/app run dev",
    "dev:web": "npm --workspace @liwu/web run dev",
    "dev:admin": "npm --workspace @liwu/admin run dev",
    "build": "npm run build:app",
    "build:app": "npm --workspace @liwu/app run build",
    "build:web": "npm --workspace @liwu/web run build",
    "build:admin": "npm --workspace @liwu/admin run build",
    "build:miniprogram": "npm --workspace @liwu/miniprogram run build",
    "build:server": "npm --workspace @liwu/server run build",
    "lint": "eslint .",
    "preview": "npm --workspace @liwu/app run preview",
    "preview:admin": "npm --workspace @liwu/admin run preview"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "^2.25.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
